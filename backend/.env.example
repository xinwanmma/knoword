# ============================================
# RAG 知识库系统 - 环境变量模板
# 复制此文件为 .env 并修改配置
# ============================================

# --- 数据库 ---
DATABASE_URL=postgresql+asyncpg://rag_user:rag_password@localhost:5432/rag_kb
DATABASE_URL_SYNC=postgresql://rag_user:rag_password@localhost:5432/rag_kb

# --- ChromaDB ---
CHROMADB_PATH=./data/chromadb

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen3.5:2b
OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b

# --- JWT 认证（必须修改） ---
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- 分块配置 ---
CHUNK_TARGET_TOKENS=300
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_SENTENCES=2

# --- 文件上传 ---
MAX_UPLOAD_SIZE_MB=50

# --- Store 会话状态 ---
STORE_ENABLED=true
STORE_CACHE_TTL_DAYS=30
STORE_CACHE_SIMILARITY_THRESHOLD=0.9
STORE_AUTO_EXTRACT=true

# --- 默认管理员（首次启动自动创建） ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_EMAIL=admin@example.com

# --- 调试模式 ---
DEBUG=false
