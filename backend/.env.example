# ============================================
# RAG 知识库系统 - 环境变量模板
# ============================================
# 启动前必看：找到带 [!] 标记的配置，按需修改
# 复制此文件为 .env:  cp .env.example .env
# ============================================


# ============================================
# ★★★ 必填项（用户必须修改）★★★
# ============================================

# [!] MiMo API Key（默认生成模型，必填）
#     申请地址: https://api.xiaomimimo.com/
MIMO_API_KEY=                                  # ← 填入你的 API Key

# [!] JWT 密钥（生产环境必改，否则 token 可被伪造）
#     生成方法: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production

# [!] 默认管理员密码（首次启动自动创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456                     # ← 生产环境请改
ADMIN_EMAIL=admin@example.com

# [!] HF 模型本地缓存目录（embedding + rerank 共用）
#     Windows 示例:  C:\Users\你的用户名\.cache\huggingface\hub
#     Linux 示例:    /home/yourname/.cache/huggingface/hub
#     macOS 示例:    /Users/yourname/.cache/huggingface/hub
HF_CACHE_DIR=C:\Users\13596\.cache\huggingface\hub

# [!] HF 离线模式（1=强制离线，0=允许联网下载新模型）
#     已下载好的模型设 1，启动更快
HF_OFFLINE=1


# ============================================
# 可选项 — 第三方 API Key（不填则该 provider 不可用）
# ============================================

# DeepSeek（云端 LLM，可选）
DEEPSEEK_API_KEY=                              # ← 不填则不能用 DeepSeek

# GLM 智谱（云端 LLM，可选）
GLM_API_KEY=                                   # ← 不填则不能用 GLM

# SiliconFlow（云端 Embedding + Rerank，可选）
# 申请地址: https://siliconflow.cn/
SILICONFLOW_API_KEY=                           # ← 不填则不能用云端 Embedding/Rerank


# ============================================
# 数据库（PostgreSQL 14+）
# ============================================
# 默认连接本机 PostgreSQL，如修改地址请同步改两个 URL
DATABASE_URL=postgresql+asyncpg://rag_user:rag_password@localhost:5432/rag_kb
DATABASE_URL_SYNC=postgresql://rag_user:rag_password@localhost:5432/rag_kb

# ============================================
# ChromaDB（本地持久化，目录不存在会自动创建）
# ============================================
CHROMADB_PATH=./data/chromadb

# ============================================
# 分块默认配置（每个 KB 可在管理界面独立覆盖）
# ============================================
CHUNK_TARGET_TOKENS=300
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_SENTENCES=2

# ============================================
# 文件上传
# ============================================
MAX_UPLOAD_SIZE_MB=50

# ============================================
# 调试模式
# ============================================
DEBUG=false


# ============================================
# LLM（生成模型）— 全部 OpenAI 兼容协议
# 配置上面 LLM_API_KEY 即可使用对应 Provider
# ============================================

# --- MiMo（小米）— 默认生成模型 ---
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro                       # 默认生成模型
MIMO_LITE_MODEL=mimo-2.5                       # LLM-as-Judge / RAGAS 评估器固定使用
MIMO_LLM_TEMPERATURE=0.7

# --- DeepSeek ---
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# --- GLM 智谱 ---
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=GLM-4.5-flash


# ============================================
# Embedding（至少需要一种 provider 可用）
# ============================================

# --- Ollama（本地，推荐，零成本）---
#     启动前需: ollama pull qwen3-embedding:0.6b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b

# --- HuggingFace 本地（离线，模型已在本地缓存）---
HF_EMBED_MODEL=shibing624/text2vec-base-chinese

# --- SiliconFlow（云端 API）---
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_EMBED_8B=Qwen/Qwen3-Embedding-8B
SILICONFLOW_EMBED_4B=Qwen/Qwen3-Embedding-4B


# ============================================
# Rerank（重排序，可选但推荐）
# 不配置时仅做向量检索
# ============================================

# --- HuggingFace 本地（CrossEncoder，与 embedding 共享缓存目录）---
HF_RERANK_MODEL=BAAI/bge-reranker-base

# --- SiliconFlow（云端 API）---
SILICONFLOW_RERANK_MODEL=Qwen/Qwen3-Reranker-4B
SILICONFLOW_RERANK_URL=https://api.siliconflow.cn/v1/rerank


# ============================================
# 评估系统（Evaluation Center）
# 报告输出到 backend/reports/ 永久保留
# ============================================

# 评估任务默认参数
DEFAULT_EVAL_QA_COUNT=20                       # 自动生成数据集默认 20 道题
DEFAULT_EVAL_CONCURRENCY=4                     # 评估并行度（1-8）

# 报告输出目录（每个 run 输出 .json + .md）
EVAL_REPORT_DIR=./reports

# LLM-as-Judge 固定使用 MIMO_LITE_MODEL（无需单独配置）

# RAGAS 评估开关（run 完成后批量跑 6 维评估）
# RAGAS 会调用 LLM-as-Judge 同款 LLM + Ollama embedding 评估一次
# 启用前需先安装: pip install ragas datasets
# 注意: RAGAS 比 LLM-as-Judge 慢 5-10x，建议在结果对比阶段开启
USE_RAGAS=false


# ============================================
# 默认策略（新建 KB 时使用，用户可在管理界面调整）
# ============================================
DEFAULT_EMBEDDING=qwen3-embedding:0.6b
DEFAULT_CHUNKING=recursive
DEFAULT_RETRIEVAL=vector
DEFAULT_LLM=mimo-v2.5-pro
