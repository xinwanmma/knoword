# ============================================
# RAG 知识库系统 - .gitignore
# ============================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
*.whl

# --- 虚拟环境 ---
venv/
.venv/
env/
.env.local

# --- 环境变量（包含密钥，不要提交） ---
backend/.env
.env

# --- 后端运行时数据 ---
backend/data/
backend/reports/
backend/test.db
backend/test_chromadb/
backend/*.db

# --- 前端 ---
frontend/node_modules/
frontend/dist/

# --- 测试 ---
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- 工具配置（本地生成，不要提交） ---
.codegraph/
.reasonix/
reasonix.toml

# --- OS ---
.DS_Store
Thumbs.db

# --- 日志 ---
*.log
logs/
